rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isOwner() {
      return request.auth != null && request.auth.uid == "OWNER_UID";
    }

    // Uploaded CSVs live under /users/{uid}/projects/{projectId}/sources/{sourceId}/<file>
    match /users/{uid}/{allPaths=**} {
      allow read, write: if isOwner() && request.auth.uid == uid;
    }
  }
}
