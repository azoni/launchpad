rules_version = '2';

// Single-user app: only the owner UID can read/write anything.
// Replace dQNAeA4B8DNYrc0yGvQvh1IZ16v2 below with your Firebase Auth UID after first sign-in,
// then run `firebase deploy --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null && request.auth.uid == "dQNAeA4B8DNYrc0yGvQvh1IZ16v2";
    }

    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
