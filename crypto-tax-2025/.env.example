# Firebase client config — safe to expose, used by the React app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Your allowed Firebase Auth UID. Set this AFTER your first Google sign-in.
# Find it in Firebase Console -> Authentication -> Users.
# Used both client-side (gate) and inside firestore.rules / storage.rules.
VITE_ALLOWED_UID=

# Launchpad analytics — view beacon, fires once per session
VITE_MCP_READ_KEY=

# Server-side secrets (Netlify Functions only — never exposed to the browser)
ANTHROPIC_API_KEY=
MCP_ADMIN_KEY=
